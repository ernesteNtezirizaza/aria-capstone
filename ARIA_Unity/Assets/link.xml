<linker>
  <!--
    GameObject.CreatePrimitive() adds Collider components (BoxCollider, SphereCollider,
    CapsuleCollider, MeshCollider) internally from engine code, with no direct C# reference
    anywhere in our scripts. Without this, IL2CPP's code stripper removes those managed
    wrapper classes from the WebGL build, and CreatePrimitive logs
    "Can't add component because class 'X' doesn't exist!" at runtime instead of failing
    the build.
  -->
  <assembly fullname="UnityEngine.PhysicsModule" preserve="all" />

  <!--
    ARIAPolicyInference references Unity.InferenceEngine.ModelAsset directly, so that one
    type survives stripping, but Resources.Load<ModelAsset>("aria_policy") still returns
    null in the WebGL build because ModelAsset's deserialization depends on
    ModelAssetData/ModelAssetWeightsData and other package-internal types that nothing in
    our own code references by name, so the linker drops them.
  -->
  <assembly fullname="Unity.InferenceEngine" preserve="all" />
</linker>
